<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sunway Payment Link Demo</title>
  <link rel="stylesheet" href="/css/workbench-theme.css" />
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      padding: clamp(0.8rem, 2vw, 1.2rem);
      background:
        radial-gradient(circle at 8% 10%, rgba(14, 165, 233, 0.12), transparent 28%),
        radial-gradient(circle at 92% 85%, rgba(251, 191, 36, 0.14), transparent 30%),
        linear-gradient(180deg, #f8fbff 0%, #eef3f8 100%);
      color: #10243a;
    }

    .shell {
      max-width: 920px;
      margin: 0 auto;
      border-radius: 18px;
      border: 1px solid rgba(15, 23, 42, 0.08);
      background: #ffffff;
      box-shadow: 0 20px 38px rgba(15, 23, 42, 0.08);
      overflow: hidden;
    }

    .header {
      padding: 1.1rem 1.2rem;
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.8rem;
      flex-wrap: wrap;
      background: linear-gradient(110deg, #f2f8ff 0%, #f8fbff 70%, #fffaf0 100%);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      min-width: 0;
    }

    .logo-placeholder {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      border: 2px dashed #8aa8c7;
      background: #ffffff;
      display: grid;
      place-items: center;
      font-size: 0.66rem;
      color: #4b6b8f;
      font-weight: 700;
      text-transform: uppercase;
      flex-shrink: 0;
    }

    .brand-copy {
      display: grid;
      gap: 0.1rem;
      min-width: 0;
    }

    .brand-subtitle {
      margin: 0;
      font-size: 0.78rem;
      color: #4b6580;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .title {
      margin: 0;
      font-size: 1.2rem;
      letter-spacing: -0.01em;
      color: #0f2c4d;
    }

    .home-link {
      border-radius: 10px;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 700;
      color: #0f2c4d;
      border: 1px solid rgba(15, 23, 42, 0.14);
      background: #ffffff;
      padding: 0.42rem 0.72rem;
    }

    .home-link:hover {
      background: #eff6ff;
    }

    .body {
      padding: clamp(1rem, 2vw, 1.4rem);
      display: grid;
      gap: 1rem;
    }

    .intro {
      margin: 0;
      color: #334e68;
      line-height: 1.45;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
    }

    .field {
      display: grid;
      gap: 0.4rem;
    }

    .field.full {
      grid-column: 1 / -1;
    }

    .field label {
      font-size: 0.82rem;
      color: #334e68;
      font-weight: 600;
    }

    .input,
    .select {
      width: 100%;
      border-radius: 10px;
      border: 1px solid #cbd5e1;
      background: #ffffff;
      color: #10243a;
      padding: 0.58rem 0.66rem;
      font-size: 0.92rem;
      outline: none;
    }

    .input:focus,
    .select:focus {
      border-color: rgba(56, 189, 248, 0.5);
      box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.14);
    }

    .meta-row {
      display: flex;
      gap: 0.55rem;
      flex-wrap: wrap;
      color: #5c738f;
      font-size: 0.78rem;
    }

    .rate-banner {
      grid-column: 1 / -1;
      border-radius: 12px;
      border: 1px solid rgba(14, 165, 233, 0.35);
      background: rgba(14, 165, 233, 0.1);
      color: #0f2c4d;
      padding: 0.9rem 0.78rem;
      display: none;
      gap: 0.28rem;
      text-align: center;
      justify-items: center;
    }

    .rate-banner.show {
      display: grid;
    }

    .rate-banner-title {
      margin: 0;
      font-weight: 700;
      font-size: 0.9rem;
      color: #0b3d66;
    }

    .rate-banner-line {
      margin: 0;
      font-size: 0.85rem;
      color: #1e3a56;
      line-height: 1.4;
    }

    .rate-banner-amount {
      margin: 0;
      font-size: 1.42rem;
      line-height: 1.2;
      font-weight: 800;
      color: #0f2c4d;
    }

    .rate-banner-rate {
      margin: 0;
      font-size: 0.76rem;
      color: #35536d;
    }

    .rate-banner-gap {
      height: 0.22rem;
    }

    .rate-banner-note {
      margin: 0;
      font-size: 0.78rem;
      color: #35536d;
    }

    .rate-banner.empty {
      border-color: rgba(245, 158, 11, 0.45);
      background: rgba(245, 158, 11, 0.12);
    }

    .chip {
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: #f8fbff;
      border-radius: 999px;
      padding: 0.25rem 0.52rem;
    }

    .submit {
      border-radius: 10px;
      border: 1px solid #0ea5e9;
      background: #0ea5e9;
      color: #ffffff;
      font-size: 0.9rem;
      font-weight: 700;
      padding: 0.62rem 0.75rem;
      cursor: pointer;
    }

    .submit:hover {
      background: #0284c7;
      border-color: #0284c7;
    }

    .submit:disabled {
      cursor: progress;
      opacity: 0.72;
    }

    .result {
      border-radius: 12px;
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: #f8fbff;
      padding: 0.85rem;
      display: grid;
      gap: 0.55rem;
    }

    .history {
      border-radius: 12px;
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: #ffffff;
      padding: 0.75rem;
      display: none;
      gap: 0.55rem;
    }

    .history h3 {
      margin: 0;
      font-size: 0.92rem;
      color: #0f2c4d;
    }

    .history-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 0.45rem;
    }

    .history-item {
      border: 1px solid rgba(148, 163, 184, 0.25);
      border-radius: 10px;
      padding: 0.55rem 0.6rem;
      display: grid;
      gap: 0.22rem;
      background: #f8fbff;
    }

    .history-line {
      margin: 0;
      font-size: 0.8rem;
      color: #334e68;
      word-break: break-word;
    }

    .status-pill {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 0.1rem 0.45rem;
      font-size: 0.74rem;
      font-weight: 700;
      border: 1px solid rgba(148, 163, 184, 0.35);
      color: #334e68;
      background: #f8fafc;
      width: fit-content;
    }

    .status-pill.paid {
      color: #166534;
      background: #dcfce7;
      border-color: rgba(22, 163, 74, 0.35);
    }

    .status-pill.failed {
      color: #991b1b;
      background: #fee2e2;
      border-color: rgba(220, 38, 38, 0.35);
    }

    .payment-status {
      margin-top: 0.35rem;
      border-radius: 11px;
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: rgba(148, 163, 184, 0.1);
      padding: 0.65rem 0.75rem;
      display: grid;
      justify-items: center;
      gap: 0.25rem;
      text-align: center;
    }

    .status-icon {
      width: 34px;
      height: 34px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      font-size: 1rem;
      font-weight: 900;
      color: #ffffff;
      background: #94a3b8;
      transform: scale(1);
    }

    .status-icon.paid {
      background: #16a34a;
      animation: paid-pop 650ms ease-out 1;
    }

    .status-icon.failed {
      background: #dc2626;
    }

    .status-text {
      margin: 0;
      font-size: 0.85rem;
      color: #1e3a56;
      font-weight: 700;
    }

    @keyframes paid-pop {
      0% { transform: scale(0.7); opacity: 0.5; }
      60% { transform: scale(1.15); opacity: 1; }
      100% { transform: scale(1); opacity: 1; }
    }

    .qr-wrap {
      display: grid;
      gap: 0.4rem;
      justify-items: center;
      margin-top: 0.25rem;
    }

    .qr-wrap img {
      width: 190px;
      height: 190px;
      border-radius: 10px;
      border: 1px solid rgba(15, 23, 42, 0.12);
      background: #ffffff;
      padding: 0.45rem;
      object-fit: contain;
    }

    .result h2 {
      margin: 0;
      font-size: 0.93rem;
      color: #0f2c4d;
    }

    .kv {
      margin: 0;
      color: #334e68;
      font-size: 0.85rem;
    }

    .kv strong {
      color: #10243a;
      font-weight: 700;
    }

    .link {
      color: #0369a1;
      text-decoration: none;
      word-break: break-word;
    }

    .link:hover {
      text-decoration: underline;
    }

    .error {
      border: 1px solid rgba(239, 68, 68, 0.45);
      background: rgba(239, 68, 68, 0.15);
      color: #fecaca;
      border-radius: 10px;
      padding: 0.62rem 0.7rem;
      font-size: 0.85rem;
      display: none;
    }

    @media (max-width: 720px) {
      body {
        padding: 0.55rem;
      }

      .header {
        padding: 0.9rem;
      }

      .logo-placeholder {
        width: 38px;
        height: 38px;
      }

      .title {
        font-size: 1.06rem;
      }

      .form-grid {
        grid-template-columns: 1fr;
      }

      .home-link {
        width: 100%;
        text-align: center;
      }
    }
  </style>
</head>
<body>
  <main class="shell">
    <header class="header">
      <div class="brand">
        <div class="logo-placeholder" aria-hidden="true">Logo</div>
        <div class="brand-copy">
          <h1 class="title">Sunway Payment Link Demo</h1>
          <p class="brand-subtitle">Logo placeholder ready for merchant branding</p>
        </div>
      </div>
      <a class="home-link" href="/custom-demos/sunway">Dashboard</a>
    </header>

    <section class="body">
      <p class="intro">Create an Adyen payment link using MYR input, converted into the selected target currency and country locale.</p>

      <div class="meta-row">
        <a class="home-link" href="/custom-demos/sunway" style="padding:0.32rem 0.58rem; font-size:0.78rem;">Back to dashboard</a>
        <a class="home-link" href="/custom-demos/sunway/history" style="padding:0.32rem 0.58rem; font-size:0.78rem;">View history</a>
      </div>

      <form id="sunway-form" class="form-grid">
        <div class="field">
          <label for="targetCurrency">Target currency</label>
          <select id="targetCurrency" name="targetCurrency" class="select" required>
            <option value="MYR">MYR</option>
            <option value="SGD">SGD</option>
            <option value="IDR">IDR</option>
            <option value="THB">THB</option>
            <option value="VND">VND</option>
            <option value="JPY">JPY</option>
            <option value="CNY">CNY</option>
          </select>
        </div>

        <div class="field">
          <label for="amountMyr">Amount in MYR</label>
          <input id="amountMyr" name="amountMyr" class="input" type="number" min="0.01" step="0.01" placeholder="e.g. 129.90" required />
        </div>

        <div id="rateBanner" class="rate-banner" aria-live="polite"></div>

        <div class="field">
          <label for="emailAddress">Email address</label>
          <input id="emailAddress" name="emailAddress" class="input" type="email" placeholder="name@example.com" />
        </div>

        <div class="field">
          <label for="countryCode">Country</label>
          <select id="countryCode" name="countryCode" class="select" required>
            <option value="MY">Malaysia (MY)</option>
            <option value="SG">Singapore (SG)</option>
            <option value="ID">Indonesia (ID)</option>
            <option value="TH">Thailand (TH)</option>
            <option value="VN">Vietnam (VN)</option>
            <option value="JP">Japan (JP)</option>
            <option value="CN">China (CN)</option>
          </select>
        </div>

        <div class="field">
          <label for="paymentUsageType">Payment usage</label>
          <select id="paymentUsageType" name="paymentUsageType" class="select" required>
            <option value="one-off">One-off (tokenize card)</option>
            <option value="unscheduled-recurring">Unscheduled recurring payments</option>
          </select>
        </div>

        <div class="field">
          <label for="description">Description</label>
          <input id="description" name="description" class="input" type="text" maxlength="280" placeholder="Blue Bag - ModelM671" />
        </div>

        <div class="field">
          <label for="phoneNumber">Phone number (optional)</label>
          <input id="phoneNumber" name="phoneNumber" class="input" type="tel" placeholder="+60123456789" />
        </div>

        <div class="field full">
          <button id="submitBtn" class="submit" type="submit">Generate payment link</button>
        </div>
      </form>

      <p id="errorBox" class="error"></p>

      <section id="resultBox" class="result" style="display:none;">
        <h2>Payment Link Created</h2>
        <p class="kv"><strong>Link:</strong> <a id="linkValue" class="link" target="_blank" rel="noreferrer"></a></p>
        <p class="kv"><strong>Status:</strong> <span id="statusValue"></span></p>
        <p class="kv"><strong>Payment method:</strong> <span id="paymentMethodValue">-</span></p>
        <p class="kv"><strong>PSP reference:</strong> <span id="pspReferenceValue">-</span></p>
        <p class="kv"><strong>Recipient:</strong> <span id="recipientValue"></span></p>
        <p class="kv"><strong>Channel:</strong> <span id="channelValue"></span></p>
        <p class="kv"><strong>Expires at:</strong> <span id="expiresAtValue"></span></p>
        <div id="paymentStatusBox" class="payment-status" style="display:none;">
          <div id="paymentStatusIcon" class="status-icon">...</div>
          <p id="paymentStatusText" class="status-text">Waiting for payment authorisation.</p>
        </div>
        <div class="qr-wrap">
          <img id="qrCodeImage" alt="Payment Link QR Code" />
          <p class="rate-banner-note">Scan this QR code to open the payment link.</p>
        </div>
      </section>

      <section id="historyBox" class="history">
        <h3>Links Created In This Session</h3>
        <ul id="historyList" class="history-list"></ul>
      </section>
    </section>
  </main>

  <script>
    (() => {
      const initialEnv = '<%= env %>';
      const form = document.getElementById('sunway-form');
      const submitBtn = document.getElementById('submitBtn');
      const errorBox = document.getElementById('errorBox');
      const resultBox = document.getElementById('resultBox');
      const targetCurrencyInput = document.getElementById('targetCurrency');
      const amountMyrInput = document.getElementById('amountMyr');
      const countryCodeInput = document.getElementById('countryCode');
      const rateBanner = document.getElementById('rateBanner');
      const linkValue = document.getElementById('linkValue');
      const statusValue = document.getElementById('statusValue');
      const paymentMethodValue = document.getElementById('paymentMethodValue');
      const pspReferenceValue = document.getElementById('pspReferenceValue');
      const recipientValue = document.getElementById('recipientValue');
      const channelValue = document.getElementById('channelValue');
      const expiresAtValue = document.getElementById('expiresAtValue');
      const paymentStatusBox = document.getElementById('paymentStatusBox');
      const paymentStatusIcon = document.getElementById('paymentStatusIcon');
      const paymentStatusText = document.getElementById('paymentStatusText');
      const qrCodeImage = document.getElementById('qrCodeImage');
      const historyBox = document.getElementById('historyBox');
      const historyList = document.getElementById('historyList');
      let rateLookupTimer = null;
      let rateLookupSeq = 0;
      let paymentStatusPollTimer = null;
      let latestStatusToken = 0;
      const linksHistory = [];
      let activePaymentLinkKey = null;

      const showError = (message) => {
        errorBox.textContent = message;
        errorBox.style.display = 'block';
      };

      const clearError = () => {
        errorBox.textContent = '';
        errorBox.style.display = 'none';
      };

      const formatAmountByCode = (value, currency) => {
        const amount = new Intl.NumberFormat('en-US', {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2
        }).format(value);

        return `${currency} ${amount}`;
      };

      const formatRate = (value) => {
        if (!Number.isFinite(value)) {
          return '-';
        }

        return value.toFixed(3);
      };

      const formatLocalDateTime = (value) => {
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) {
          return '-';
        }

        return date.toLocaleString(undefined, {
          dateStyle: 'medium',
          timeStyle: 'short'
        });
      };

      const hideRateBanner = () => {
        rateBanner.classList.remove('show');
        rateBanner.classList.remove('empty');
        rateBanner.innerHTML = '';
      };

      const resetPaymentStatus = () => {
        paymentStatusBox.style.display = 'none';
        paymentStatusIcon.className = 'status-icon';
        paymentStatusIcon.textContent = '...';
        paymentStatusText.textContent = 'Waiting for payment authorisation.';
      };

      const renderPaymentStatus = (statusValueRaw) => {
        const normalized = String(statusValueRaw || '').toLowerCase();
        paymentStatusBox.style.display = 'grid';

        if (normalized === 'paid') {
          paymentStatusIcon.className = 'status-icon paid';
          paymentStatusIcon.textContent = '✓';
          paymentStatusText.textContent = 'Customer has paid.';
          return;
        }

        if (normalized === 'payment failed') {
          paymentStatusIcon.className = 'status-icon failed';
          paymentStatusIcon.textContent = '!';
          paymentStatusText.textContent = 'Payment failed.';
          return;
        }

        paymentStatusIcon.className = 'status-icon';
        paymentStatusIcon.textContent = '...';
        paymentStatusText.textContent = 'Waiting for payment authorisation.';
      };

      const stopPaymentStatusPolling = () => {
        if (paymentStatusPollTimer) {
          clearInterval(paymentStatusPollTimer);
          paymentStatusPollTimer = null;
        }
      };

      const normalizeStatusClass = (statusRaw) => {
        const normalized = String(statusRaw || '').toLowerCase();
        if (normalized === 'paid') {
          return 'paid';
        }

        if (normalized === 'payment failed') {
          return 'failed';
        }

        return '';
      };

      const getEntryKey = (entry) => `${entry.merchantAccountCode}::${entry.paymentLinkId}`;

      const renderHistory = () => {
        if (linksHistory.length === 0) {
          historyBox.style.display = 'none';
          historyList.innerHTML = '';
          return;
        }

        const rows = linksHistory
          .slice()
          .reverse()
          .map((entry) => {
            const statusClass = normalizeStatusClass(entry.status);
            const createdAt = entry.createdAt
              ? new Date(entry.createdAt).toLocaleString()
              : '-';

            return `
              <li class="history-item">
                <p class="history-line"><strong>ID:</strong> ${entry.paymentLinkId}</p>
                <p class="history-line"><strong>Merchant:</strong> ${entry.merchantAccountCode}</p>
                <p class="history-line"><strong>Created:</strong> ${createdAt}</p>
                <p class="history-line"><strong>Payment method:</strong> ${entry.paymentMethod || '-'}</p>
                <p class="history-line"><strong>PSP reference:</strong> ${entry.pspReference || '-'}</p>
                <p class="history-line"><strong>Link:</strong> <a class="link" href="${entry.paymentLinkUrl}" target="_blank" rel="noreferrer">${entry.paymentLinkUrl}</a></p>
                <span class="status-pill ${statusClass}">${entry.status || 'pending'}</span>
              </li>
            `;
          })
          .join('');

        historyList.innerHTML = rows;
        historyBox.style.display = 'grid';
      };

      const upsertHistoryEntry = (entry) => {
        const key = getEntryKey(entry);
        const index = linksHistory.findIndex((item) => getEntryKey(item) === key);

        if (index === -1) {
          linksHistory.push(entry);
        } else {
          linksHistory[index] = {
            ...linksHistory[index],
            ...entry
          };
        }

        renderHistory();
      };

      const getActiveEntry = () => {
        if (!activePaymentLinkKey) {
          return null;
        }

        return linksHistory.find((entry) => getEntryKey(entry) === activePaymentLinkKey) || null;
      };

      const renderLatestPaymentPanel = (entry) => {
        if (!entry) {
          return;
        }

        linkValue.textContent = entry.paymentLinkUrl || '-';
        linkValue.href = entry.paymentLinkUrl || '#';
        statusValue.textContent = entry.status || 'pending';
        paymentMethodValue.textContent = entry.paymentMethod || '-';
        pspReferenceValue.textContent = entry.pspReference || '-';
        recipientValue.textContent = entry.recipient || '-';
        channelValue.textContent = entry.channel || '-';
        expiresAtValue.textContent = entry.expiresAt || '-';
        qrCodeImage.src = `https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=${encodeURIComponent(entry.paymentLinkUrl || '')}`;
        renderPaymentStatus(entry.status);
        resultBox.style.display = 'grid';
      };

      const startPaymentStatusPolling = ({ paymentLinkId, merchantAccountCode }) => {
        stopPaymentStatusPolling();
        const token = latestStatusToken + 1;
        latestStatusToken = token;
        paymentStatusBox.style.display = 'grid';

        const run = async () => {
          try {
            const snapshots = linksHistory.slice();
            for (const entry of snapshots) {
              const query = new URLSearchParams({ merchantAccountCode: entry.merchantAccountCode });
              const response = await fetch(`/api/custom-demos/sunway/payment-link-status/${encodeURIComponent(entry.paymentLinkId)}?${query.toString()}`);
              const data = await response.json();

              if (token !== latestStatusToken) {
                return;
              }

              if (!response.ok) {
                continue;
              }

              upsertHistoryEntry({
                ...entry,
                status: data.status || entry.status,
                paymentMethod: data.paymentMethod || entry.paymentMethod,
                pspReference: data.pspReference || entry.pspReference
              });
            }

            const activeEntry = getActiveEntry();
            if (activeEntry) {
              renderLatestPaymentPanel(activeEntry);
            }
          } catch (_error) {
            // Keep polling silently for demo UX.
          }
        };

        run();
        paymentStatusPollTimer = setInterval(run, 2000);
      };

      const showNoRateBanner = ({ targetCurrency, amountMyr, reason }) => {
        rateBanner.innerHTML = `
          <p class="rate-banner-title">FX Preview</p>
          <p class="rate-banner-line">No rate available for MYR to <strong>${targetCurrency}</strong> right now.</p>
          <p class="rate-banner-amount">${formatAmountByCode(amountMyr, 'MYR')}</p>
          <p class="rate-banner-note">${reason || 'Try again later or check if the latest report has been processed.'}</p>
        `;
        rateBanner.classList.add('show');
        rateBanner.classList.add('empty');
      };

      const showRateBanner = ({
        targetCurrency,
        amountMyr,
        exchangeRate,
        reverseSettlementRate,
        converted,
        convertedSettlementMyr,
        validFrom
      }) => {
        const settlementBlock = Number.isFinite(reverseSettlementRate)
          ? `
            <p class="rate-banner-line">You will receive at est. settlement</p>
            <p class="rate-banner-amount">${formatAmountByCode(convertedSettlementMyr, 'MYR')}</p>
            <p class="rate-banner-rate">(est. settlement rate ${targetCurrency}->MYR: ${formatRate(reverseSettlementRate)})</p>
          `
          : `
            <p class="rate-banner-line">You will receive at est. settlement</p>
            <p class="rate-banner-rate">(est. settlement rate ${targetCurrency}->MYR: unavailable)</p>
          `;

        rateBanner.innerHTML = `
          <p class="rate-banner-line">You will be charging customer:</p>
          <p class="rate-banner-amount">${formatAmountByCode(converted, targetCurrency)}</p>
          <p class="rate-banner-rate">(rate MYR->${targetCurrency}: ${formatRate(exchangeRate)})</p>
          <div class="rate-banner-gap"></div>
          ${settlementBlock}
          <p class="rate-banner-note">This rate is valid from ${formatLocalDateTime(validFrom)}</p>
        `;
        rateBanner.classList.remove('empty');
        rateBanner.classList.add('show');
      };

      const refreshRateBanner = async () => {
        const amountMyr = Number(amountMyrInput.value);
        const targetCurrency = String(targetCurrencyInput.value || '').toUpperCase();

        if (!Number.isFinite(amountMyr) || amountMyr <= 0 || !targetCurrency) {
          hideRateBanner();
          return;
        }

        if (targetCurrency === 'MYR') {
          showRateBanner({
            targetCurrency,
            amountMyr,
            exchangeRate: 1,
            reverseSettlementRate: 1,
            converted: amountMyr,
            convertedSettlementMyr: amountMyr,
            validFrom: 'Immediate'
          });
          return;
        }

        const requestId = rateLookupSeq + 1;
        rateLookupSeq = requestId;

        try {
          const query = new URLSearchParams({
            base: 'MYR',
            target: targetCurrency
          });
          const response = await fetch(`/api/custom-demos/reports/rates?${query.toString()}`);
          const data = await response.json();

          if (requestId !== rateLookupSeq) {
            return;
          }

          if (!response.ok) {
            showNoRateBanner({
              targetCurrency,
              amountMyr,
              reason: data.reason || 'No rates file found for the selected date.'
            });
            return;
          }

          const reverseQuery = new URLSearchParams({
            base: targetCurrency,
            target: 'MYR'
          });
          const reverseResponse = await fetch(`/api/custom-demos/reports/rates?${reverseQuery.toString()}`);
          const reverseData = await reverseResponse.json();

          if (!reverseResponse.ok) {
            showNoRateBanner({
              targetCurrency,
              amountMyr,
              reason: reverseData.reason || `No reverse settlement rate found for ${targetCurrency} to MYR.`
            });
            return;
          }

          const exchangeRate = Number(data.exchangeRate);
          const reverseSettlementRate = Number(reverseData.exchangePlatformSettlement);
          if (!Number.isFinite(exchangeRate) || exchangeRate <= 0) {
            showNoRateBanner({
              targetCurrency,
              amountMyr,
              reason: 'Rate data is available but does not contain a valid exchange rate value.'
            });
            return;
          }

          if (!Number.isFinite(reverseSettlementRate) || reverseSettlementRate <= 0) {
            showNoRateBanner({
              targetCurrency,
              amountMyr,
              reason: `Reverse settlement rate for ${targetCurrency} to MYR is unavailable.`
            });
            return;
          }

          const converted = amountMyr * exchangeRate;
          const convertedSettlementMyr = converted * reverseSettlementRate;

          showRateBanner({
            targetCurrency,
            amountMyr,
            exchangeRate,
            reverseSettlementRate,
            converted,
            convertedSettlementMyr,
            validFrom: data.validFrom
          });
        } catch (error) {
          showNoRateBanner({
            targetCurrency,
            amountMyr,
            reason: error?.message || 'Unable to fetch rates at the moment.'
          });
        }
      };

      const queueRateLookup = () => {
        if (rateLookupTimer) {
          clearTimeout(rateLookupTimer);
        }

        rateLookupTimer = setTimeout(() => {
          refreshRateBanner();
        }, 300);
      };

      const countryByTargetCurrency = {
        MYR: 'MY',
        SGD: 'SG',
        USD: 'US',
        EUR: 'NL',
        HKD: 'HK'
      };

      const syncCountryToCurrency = () => {
        const targetCurrency = String(targetCurrencyInput.value || '').toUpperCase();
        const mappedCountry = countryByTargetCurrency[targetCurrency];
        if (mappedCountry) {
          countryCodeInput.value = mappedCountry;
        }
      };

      targetCurrencyInput.addEventListener('change', () => {
        syncCountryToCurrency();
        queueRateLookup();
      });
      amountMyrInput.addEventListener('input', queueRateLookup);
      syncCountryToCurrency();
      queueRateLookup();
      window.addEventListener('beforeunload', stopPaymentStatusPolling);

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        clearError();
        stopPaymentStatusPolling();
        let linkCreated = false;

        const formData = new FormData(form);
        const payload = {
          targetCurrency: String(formData.get('targetCurrency') || 'MYR').toUpperCase(),
          amountMyr: Number(formData.get('amountMyr')),
          emailAddress: String(formData.get('emailAddress') || '').trim(),
          countryCode: String(formData.get('countryCode') || 'MY').toUpperCase(),
          paymentUsageType: String(formData.get('paymentUsageType') || 'one-off').trim().toLowerCase(),
          description: String(formData.get('description') || '').trim(),
          phoneNumber: String(formData.get('phoneNumber') || '').trim(),
          isLive: initialEnv === 'live'
        };

        if (!payload.emailAddress) {
          showError('Please enter an email address. It is used as shopperReference.');
          return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Generating...';

        try {
          const response = await fetch('/api/custom-demos/sunway/payment-link', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
          });

          const data = await response.json();
          if (!response.ok) {
            throw new Error(data.error || 'Unable to generate payment link.');
          }

          const newEntry = {
            paymentLinkId: data.paymentLinkId,
            merchantAccountCode: data.merchantAccountCode,
            paymentLinkUrl: data.paymentLinkUrl,
            recipient: data.recipient || '-',
            channel: data.channel || '-',
            expiresAt: data.expiresAt || '-',
            paymentMethod: '-',
            pspReference: '-',
            status: 'pending',
            createdAt: new Date().toISOString()
          };

          activePaymentLinkKey = getEntryKey(newEntry);
          upsertHistoryEntry(newEntry);
          renderLatestPaymentPanel(newEntry);
          linkCreated = true;

          if (data.paymentLinkId && data.merchantAccountCode) {
            startPaymentStatusPolling({
              paymentLinkId: data.paymentLinkId,
              merchantAccountCode: data.merchantAccountCode
            });
          }
        } catch (error) {
          showError(error.message || 'Unable to generate payment link.');
        } finally {
          if (linkCreated) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Create another one';
          } else {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Generate payment link';
          }
        }
      });
    })();
  </script>
</body>
</html>
