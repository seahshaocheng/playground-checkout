<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Adyen Drop-in Demo</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-SgOJa3DmI69IUzQ2PVdRZhwQ+dy64/BUtbMJw1MZ8t5HZApcHrRKUc4W0kG879m7" crossorigin="anonymous">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js" integrity="sha384-k6d4wzSIapyDyv1kpU366/PK5hCdSbCRGRCMv+eplOQJWyd1fbcAu9OCUj5zNLiq" crossorigin="anonymous"></script>

  <!-- Adyen SDK CSS/JS -->
  <link rel="stylesheet" href="https://checkoutshopper-<%= env %>.adyen.com/checkoutshopper/sdk/<%= sdkVersion %>/adyen.css" />
  <script src="https://checkoutshopper-<%= env %>.adyen.com/checkoutshopper/sdk/<%= sdkVersion %>/adyen.js"></script>

  <!-- Inject client key -->
  <script>
    const initialEnv = "<%= env %>";
    const sdkVersion = "<%= sdkVersion %>";
    const clientKeys = {
      test: "<%= testClientKey || clientKey %>",
      live: "<%= liveClientKey || clientKey %>"
    };
  </script>

  <style>
    .container {
      margin-top: 3rem;
    }

    .form-box {
      background: #ffffff;
      border-radius: 8px;
      padding: 2rem;
      box-shadow: 0 0 20px rgba(0,0,0,0.05);
    }

    #dropin-container {
      background: #fff;
      padding: 1.5rem;
      border-radius: 8px;
      box-shadow: 0 0 20px rgba(0,0,0,0.05);
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="d-flex justify-content-end mb-3">
      <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="environmentToggle">
        <label class="form-check-label" for="environmentToggle" id="environmentToggleLabel">Test</label>
      </div>
    </div>
    <h1 class="text-center">Adyen Drop-in Demo</h1>
    <div class="row">
      <!-- Configuration on top (mobile) / right (desktop) -->
      <div class="col-md-4 order-1 order-md-2 mb-4 mb-md-0">
        <div class="form-box">
          <form id="dropinForm">
            <%- include('shared-dropin-configuration-form') %>
            <button type="submit" class="btn btn-primary w-100">Start Drop-in</button>
          </form>
        </div>
      </div>

      <!-- Drop-in always on bottom (mobile) / left (desktop) -->
      <div class="col-md-8 order-2 order-md-1">
        <div id="dropin-container"></div>
      </div>
    </div>
  </div>

  <!-- Bootstrap JS (optional) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    const form = document.getElementById("dropinForm");
    const environmentToggle = document.getElementById("environmentToggle");
    const environmentToggleLabel = document.getElementById("environmentToggleLabel");
    const { AdyenCheckout, Dropin} = window.AdyenWeb;
    const dropinContainer = document.getElementById('dropin-container');

    const updateEnvironmentLabel = (isLive) => {
      environmentToggleLabel.textContent = isLive ? 'Live' : 'Test';
    };

    environmentToggle.checked = initialEnv === 'live';
    updateEnvironmentLabel(environmentToggle.checked);

    environmentToggle.addEventListener('change', () => {
      const nextEnv = environmentToggle.checked ? 'live' : 'test';
      updateEnvironmentLabel(environmentToggle.checked);
      const pageUrl = new URL(window.location.href);
      pageUrl.searchParams.set('env', nextEnv);
      pageUrl.searchParams.set('version', sdkVersion);
      window.location.assign(pageUrl.toString());
    });

    const getClientKeyForEnv = (env) => clientKeys[env] || clientKeys.test;

    const extractErrorMessage = async (response) => {
      try {
        const payload = await response.json();
        return payload.message || payload.error || payload.detail || JSON.stringify(payload);
      } catch (error) {
        return `${response.status} ${response.statusText}`.trim();
      }
    };

    form.addEventListener("submit", async function (e) {
      e.preventDefault();

      const env = environmentToggle.checked ? 'live' : 'test';
      const isLive = env === 'live';
      const clientKey = getClientKeyForEnv(env);
      const amountValue = Number.parseInt(form.amount.value, 10);
      const currency = (form.currency.value || "").trim().toUpperCase();
      const reference = (form.reference.value || "").trim();

      if (!clientKey) {
        alert(`Missing client key for the ${env} environment.`);
        return;
      }

      if (!Number.isInteger(amountValue) || amountValue <= 0) {
        alert("Amount must be a positive integer in minor units.");
        return;
      }

      if (!currency) {
        alert("Currency is required.");
        return;
      }

      if (!reference) {
        alert("Reference is required.");
        return;
      }

      dropinContainer.innerHTML = "";

      try {
        const response = await fetch('/api/sessions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            isLive,
            amount: { value: amountValue, currency },
            reference,
            returnUrl: `${window.location.origin}/redirect`,
            storePaymentMethodMode:"enabled",
            shopperReference: "unique-shopper-id-12345"
          })
        });

        if (!response.ok) {
          const message = await extractErrorMessage(response);
          throw new Error(`Session creation failed: ${message}`);
        }

        const session = await response.json();
        console.log("Session response:", session);

        //optional card configutation
        	const cardConfiguration = {
            hasHolderName: true, // Show the cardholder name field.
            holderNameRequired: false, // Mark the cardholder name field as required.
          };

        //optionl drop-in configuration
        const dropinConfiguration = {
          paymentMethodsConfiguration: {
            card: cardConfiguration
          }
        };

        const configuration = {
          environment: env,
          clientKey,
          session: {
            id: session.id,
            sessionData: session.sessionData
          },
          onPaymentCompleted: (result, component) => {
            alert(`Payment result: ${result.resultCode || 'completed'}`);
          },
          onPaymentFailed: (result, component) => {
            alert(`Payment failed: ${result.resultCode || 'Unknown error'}`);
            console.log('Payment failed:', result);
          },
          onError: (err) => {
            const message = err?.message || err?.name || 'Unknown error';
            alert(`Checkout error: ${message}`);
            console.error('Error:', err);
          }
        };

        const checkout = await AdyenCheckout(configuration);
        new Dropin(checkout, dropinConfiguration).mount('#dropin-container');
      } catch (error) {
        alert(error.message || 'Failed to start checkout.');
        console.error('Failed to initialize drop-in:', error);
      }
    });
  </script>
</body>
</html>
