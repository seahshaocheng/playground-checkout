<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Merchant Access</title>
  <link rel="stylesheet" href="/css/workbench-theme.css" />
  <style>
    body {
      min-height: 100vh;
      margin: 0;
      display: grid;
      place-items: center;
      padding: 1rem;
      background:
        radial-gradient(circle at 15% 10%, rgba(56, 189, 248, 0.14), transparent 35%),
        radial-gradient(circle at 80% 85%, rgba(34, 197, 94, 0.1), transparent 35%),
        linear-gradient(135deg, rgba(3, 7, 18, 0.98), rgba(8, 18, 34, 0.98));
    }

    .auth-card {
      width: min(460px, 100%);
      border-radius: 18px;
      border: 1px solid rgba(137, 168, 216, 0.24);
      background: rgba(12, 24, 42, 0.96);
      box-shadow: 0 24px 48px rgba(0, 0, 0, 0.4);
      padding: 1.35rem;
    }

    .auth-title {
      margin: 0;
      color: var(--text-0);
      font-size: 1.3rem;
      letter-spacing: -0.01em;
    }

    .auth-subtitle {
      margin: 0.45rem 0 0;
      color: var(--text-1);
      line-height: 1.45;
    }

    .auth-form {
      margin-top: 1rem;
      display: grid;
      gap: 0.8rem;
    }

    .auth-label {
      color: var(--text-0);
      font-size: 0.84rem;
      font-weight: 600;
    }

    .auth-input {
      width: 100%;
      border: 1px solid rgba(137, 168, 216, 0.26);
      background: rgba(17, 31, 53, 0.94);
      color: var(--text-0);
      border-radius: 11px;
      padding: 0.62rem 0.72rem;
      font-size: 0.94rem;
      outline: none;
    }

    .auth-input:focus {
      border-color: rgba(56, 189, 248, 0.44);
      box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.16);
    }

    .auth-button {
      appearance: none;
      border: 1px solid rgba(56, 189, 248, 0.46);
      background: rgba(56, 189, 248, 0.22);
      color: var(--text-0);
      border-radius: 11px;
      padding: 0.62rem 0.72rem;
      font-size: 0.9rem;
      font-weight: 700;
      cursor: pointer;
    }

    .auth-button:hover {
      background: rgba(56, 189, 248, 0.3);
    }

    .alert {
      border-radius: 11px;
      border: 1px solid rgba(251, 146, 60, 0.45);
      background: rgba(251, 146, 60, 0.15);
      color: #fed7aa;
      padding: 0.58rem 0.7rem;
      font-size: 0.84rem;
      line-height: 1.4;
    }

    .meta-note {
      margin-top: 0.65rem;
      font-size: 0.78rem;
      color: var(--text-2);
      line-height: 1.4;
    }

    .meta-note a {
      color: var(--accent);
      text-decoration: none;
    }

    .meta-note a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <main class="auth-card" role="main">
    <h1 class="auth-title">Merchant Demo Access</h1>
    <p class="auth-subtitle">Enter the merchant passcode to unlock hidden demos for your account.</p>

    <% if (!hasConfiguredPasscode) { %>
      <p class="alert">This environment does not have a configured merchant passcode yet.</p>
    <% } %>

    <% if (errorMessage) { %>
      <p class="alert"><%= errorMessage %></p>
    <% } %>

    <form class="auth-form" method="POST" action="/merchant-access" autocomplete="off">
      <input type="hidden" name="next" value="<%= nextPath %>" />
      <label class="auth-label" for="passcode">Passcode</label>
      <input class="auth-input" id="passcode" name="passcode" type="password" required placeholder="Enter passcode" />
      <button class="auth-button" type="submit">Unlock merchant navigation</button>
    </form>

    <p class="meta-note">Back to <a href="/">public demos</a>.</p>
  </main>
</body>
</html>
