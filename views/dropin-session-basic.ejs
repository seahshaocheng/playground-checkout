<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Adyen Drop-in Session Basic</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js"></script>

  <link rel="stylesheet" href="https://checkoutshopper-<%= env %>.adyen.com/checkoutshopper/sdk/<%= sdkVersion %>/adyen.css" />
  <script src="https://checkoutshopper-<%= env %>.adyen.com/checkoutshopper/sdk/<%= sdkVersion %>/adyen.js"></script>

  <script>
    const initialEnv = "<%= env %>";
    const sdkVersion = "<%= sdkVersion %>";
    const clientKeys = {
      test: "<%= testClientKey || clientKey %>",
      live: "<%= liveClientKey || clientKey %>"
    };
  </script>

  <style>
    body {
      min-height: 100vh;
      background: #f4f7fb;
      font-family: "Segoe UI", Tahoma, sans-serif;
      padding: 1rem;
    }

    .shell {
      max-width: 1280px;
      margin: 0 auto;
      background: #fff;
      border: 1px solid #d7e0ed;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 18px 34px rgba(11, 30, 66, 0.09);
    }

    .topbar {
      padding: 1rem 1.2rem;
      border-bottom: 1px solid #e2e8f3;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .title-wrap h1 {
      margin: 0;
      font-size: 1.25rem;
      color: #0b1f42;
    }

    .title-wrap p {
      margin: 0.3rem 0 0;
      color: #50607a;
      font-size: 0.92rem;
    }

    .controls {
      display: flex;
      gap: 0.75rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .content {
      padding: 1rem;
      display: grid;
      grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
      gap: 1rem;
      align-items: start;
    }

    .panel {
      border: 1px solid #e2e8f3;
      border-radius: 14px;
      background: #fff;
      padding: 1rem;
    }

    #dropin-container {
      min-height: 460px;
      border: 1px dashed #c8d3e5;
      border-radius: 12px;
      padding: 0.9rem;
      background: #f9fbff;
    }

    .dropin-empty {
      color: #5f6f88;
      font-size: 0.92rem;
    }

    #banner {
      min-height: 1.2rem;
    }

    @media (max-width: 960px) {
      .content {
        grid-template-columns: 1fr;
      }

      #dropin-container {
        min-height: 320px;
      }
    }
  </style>
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <div class="title-wrap">
        <h1>Drop-in Session Basic</h1>
        <p>Simple session demo with config form and shopper viewport.</p>
      </div>
      <div class="controls">
        <a class="btn btn-outline-secondary btn-sm" id="home-link" href="/">Home</a>
        <div class="form-check form-switch m-0">
          <input class="form-check-input" type="checkbox" role="switch" id="environmentToggle" />
          <label class="form-check-label" for="environmentToggle" id="environmentToggleLabel">Test</label>
        </div>
      </div>
    </header>

    <main class="content">
      <section class="panel">
        <h2 class="h6 mb-3">Configuration</h2>
        <form id="dropinForm">
          <%- include('shared-dropin-configuration-form') %>
          <button type="submit" class="btn btn-primary w-100" id="startButton">Start Session Drop-in</button>
        </form>
      </section>

      <section class="panel">
        <div id="banner" class="alert d-none mb-3" role="status" aria-live="polite"></div>
        <div id="dropin-container">
          <div class="dropin-empty">Configure amount/currency/reference and start the session.</div>
        </div>
      </section>
    </main>
  </div>

  <script>
    const { AdyenCheckout } = window.AdyenWeb;
    const form = document.getElementById('dropinForm');
    const startButton = document.getElementById('startButton');
    const dropinContainer = document.getElementById('dropin-container');
    const environmentToggle = document.getElementById('environmentToggle');
    const environmentToggleLabel = document.getElementById('environmentToggleLabel');
    const homeLink = document.getElementById('home-link');
    const banner = document.getElementById('banner');

    let currentDropin = null;

    const showBanner = (message, tone = 'info') => {
      banner.className = `alert alert-${tone} mb-3`;
      banner.textContent = message;
      banner.classList.remove('d-none');
    };

    const clearBanner = () => {
      banner.className = 'alert d-none mb-3';
      banner.textContent = '';
    };

    const updateEnvironmentLabel = (isLive) => {
      environmentToggleLabel.textContent = isLive ? 'Live' : 'Test';
      homeLink.textContent = isLive ? 'Home (LIVE)' : 'Home';
      homeLink.classList.toggle('btn-warning', isLive);
      homeLink.classList.toggle('text-dark', isLive);
    };

    const parsePaymentMethodList = (value) => {
      return String(value || '')
        .split(',')
        .map((entry) => entry.trim())
        .filter(Boolean);
    };

    environmentToggle.checked = initialEnv === 'live';
    updateEnvironmentLabel(environmentToggle.checked);

    environmentToggle.addEventListener('change', () => {
      const nextEnv = environmentToggle.checked ? 'live' : 'test';
      updateEnvironmentLabel(environmentToggle.checked);
      const pageUrl = new URL(window.location.href);
      pageUrl.searchParams.set('env', nextEnv);
      pageUrl.searchParams.set('version', sdkVersion);
      window.location.assign(pageUrl.toString());
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearBanner();

      const env = environmentToggle.checked ? 'live' : 'test';
      const isLive = env === 'live';
      const clientKey = clientKeys[env] || clientKeys.test;
      const amountValue = Number.parseInt(form.amount.value, 10);
      const currency = (form.currency.value || '').trim().toUpperCase();
      const reference = (form.reference.value || '').trim();
      const allowedPaymentMethods = parsePaymentMethodList(form.allowedPaymentMethods?.value);
      const blockedPaymentMethods = parsePaymentMethodList(form.blockedPaymentMethods?.value);

      if (!clientKey) {
        showBanner(`Missing client key for ${env}.`, 'danger');
        return;
      }

      if (!Number.isInteger(amountValue) || amountValue < 0 || !currency || !reference) {
        showBanner('Amount, currency, and reference are required.', 'warning');
        return;
      }

      startButton.disabled = true;

      try {
        if (currentDropin) {
          currentDropin.unmount();
          currentDropin = null;
        }

        dropinContainer.innerHTML = '';

        const sessionRequestBody = {
          isLive,
          amount: { value: amountValue, currency },
          reference,
          returnUrl: `${window.location.origin}/redirect`
        };

        if (allowedPaymentMethods.length > 0) {
          sessionRequestBody.allowedPaymentMethods = allowedPaymentMethods;
        }

        if (blockedPaymentMethods.length > 0) {
          sessionRequestBody.blockedPaymentMethods = blockedPaymentMethods;
        }

        const response = await fetch('/api/sessions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(sessionRequestBody)
        });

        if (!response.ok) {
          const err = await response.json().catch(() => ({ error: `${response.status} ${response.statusText}` }));
          throw new Error(err.error || err.message || 'Failed to create session.');
        }

        const session = await response.json();

        const checkout = await AdyenCheckout({
          environment: env,
          clientKey,
          session,
          onPaymentCompleted: (result) => {
            const tone = result?.resultCode === 'Authorised' ? 'success' : 'warning';
            showBanner(`Payment result: ${result?.resultCode || 'Unknown'}`, tone);
          },
          onError: (error) => {
            showBanner(error?.message || 'Checkout error.', 'danger');
          }
        });

        currentDropin = checkout.create('dropin', {
          paymentMethodsConfiguration: {
            card: {
              hasHolderName: true,
              holderNameRequired: false
            }
          }
        });

        currentDropin.mount('#dropin-container');
        showBanner('Session ready. Complete payment in the Drop-in panel.', 'info');
      } catch (error) {
        showBanner(error.message || 'Unable to initialize session Drop-in.', 'danger');
      } finally {
        startButton.disabled = false;
      }
    });
  </script>
</body>
</html>
